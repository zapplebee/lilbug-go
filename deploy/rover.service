[Unit]
Description=Lilbug Rover Web Control
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=lilbug
WorkingDirectory=/home/lilbug/lilbug-go
Environment=LILBUG_HOST=0.0.0.0
Environment=LILBUG_PORT=8000
Environment=CAMERA_INDEX=0
ExecStart=/home/lilbug/lilbug-go/.venv/bin/python -m src.main
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
